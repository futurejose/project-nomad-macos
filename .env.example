# =============================================================================
# Project N.O.M.A.D — macOS M-Series Configuration
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# =============================================================================

# --- Directory ---------------------------------------------------------------
# Where NOMAD stores persistent data.
NOMAD_DIR=$HOME/project-nomad

# --- Timezone ----------------------------------------------------------------
# Use a TZ identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# --- Ports -------------------------------------------------------------------
# Change these if you have port conflicts.
NOMAD_PORT=8080          # NOMAD Command Center:  http://localhost:8080
OPEN_WEBUI_PORT=3000     # Open WebUI (AI chat):  http://localhost:3000
KIWIX_PORT=8888          # Kiwix (library):       http://localhost:8888  [optional]
KOLIBRI_PORT=8090        # Kolibri (education):   http://localhost:8090  [optional]

# --- Ollama ------------------------------------------------------------------
# Native Ollama runs on your Mac at port 11434.
# host.docker.internal resolves to your Mac's IP from inside containers.
# Do NOT change this unless Ollama is running on a different host/port.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Security ----------------------------------------------------------------
# Change this to a random string for production use.
# Generate one with: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme-use-a-random-string
